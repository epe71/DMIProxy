    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>0d0870f3-1337-4592-970c-94722de10288</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
